Counter -> {
  u8:initial
  -> {
    Change -> { u8:value }
    u8:value >>- Change -> initial
    Change -< e {value -<< e.value}
    -> {
      -> value
      increment -> {>- Change{value+1}}
      decrement -> {>- Change{value-1}}
    }
  }!
}

Text -> {
  String:text =<< ""
  =<< text ? {
    -> >- Redraw{}
  }
}

even -> %2=0
odd -> %2=1

