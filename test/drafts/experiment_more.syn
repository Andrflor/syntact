Counter:globalCounter
// counterPositive is true
bool:counterPositive =<< globalCounter.value >= 0
funWithCounter -> {
  globalCounter.decrement!
  globalCounter.increment!
}

funWithCounter! // counterPositive updates to false then to true again

State -> {
  T <- None
  T:initial
  -> {
    Update -> { T:value }
    T:value >>- Update -> initial
    Update -< e { value >>- e.value }
    update -> { T:value, >- Update{value}}
    -> {->value set->update}
  }!
}

State{"SuperString"}:myState
myState! // "SuperString"
myState.set{"Someotherstring"}!
myState! // "Someotherstring"

RefState -> {
  T <- None
  T:initial
  -> {
    Update -> { T:value }
    T:value >>- Update =<< initial
    Update -< e { value >>- e.value }
    update -> { T:value, >- Update{value}}
    -> {-> value set->update}
  }!
}

Array -> {
  T <- None
  u64:size <- 0
  -> size=0?{
    -> {}
    -> {T:  ...Array{T size-1}}
  }
}

MutableArray -> {
  T <- None
  u64:size <- 0
  -> {
    Mutate -> {T:value u64:index}
    -> size=0 ? {
      {}
      {T: >>- Mutate ...Array{T size-1}}
    }
  }!
}

Array:array{2 3 1 5 0}


u8:n -> io.input{"Number of elements:"}!

generate -> {
  u8:n
  -> n=0 ? {
    -> {}
    -> {0 ...generate{n-1}!}
  }
}

data -> generate{n}!

