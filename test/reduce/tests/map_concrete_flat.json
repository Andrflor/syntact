{
  "name": "map over a concrete list reduces flat",
  "description": "the full recursive map with the ... tail splice unfolds to the flat mapped list",
  "source": "Array -> {\n  T -> {}\n  -> {}\n  -> {T: ...Array{T}:}\n}\nmap -> {\n  T <- {}\n  E <- {}\n  Array{T}:source\n  func -> {e -> T:, -> E:}\n  -> source ? {\n    {T:(e) ...Array{T}:(r)} -> { func{e->e}! ...map{r, func}!}\n    {} -> {}\n  }\n}\n-> map{{2 3 4 5}, {u8:e, -> e+1}}!",
  "expect": "{3, 4, 5, 6}"
}
